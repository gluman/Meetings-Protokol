# MiniMax API (прямой fallback, для LLM)
MINIMAX_API_KEY=sk-cp-your_key_here
# База MiniMax API
MINIMAX_BASE_URL=https://api.minimax.io/v1
# Whisper model name (на случай если MiniMax добавит ASR endpoint)
MINIMAX_WHISPER_MODEL=MiniMax-Whisper

# AutoAI Router (используется для LLM — настоятельно рекомендуется)
AUTOAI_BASE_URL=http://192.168.0.125:8080/v1
AUTOAI_API_KEY=sk-aut-your_key_here
AUTOAI_USE=true
AUTOAI_MODEL=MiniMax-M3

# ASR: локальный whisper.cpp сервер на srv-ai1 (GPU).
# whisper-server должен быть запущен и принимать /inference
WHISPER_SERVER_URL=http://192.168.0.94:9000
WHISPER_USE=true

# API-ключ для авторизации клиентов сервиса
# Если пусто — авторизация отключена (только для dev)
# Клиенты передают: Authorization: Bearer ***
API_KEY=your_service_api_key_here

# Web-интерфейс: логин/пароль (cookie-сессия через JWT).
# Если оба пустые — web открыт без авторизации (dev-режим).
# В production ОБЯЗАТЕЛЬНО задать обе переменные.
WEB_USERNAME=admin
WEB_PASSWORD=your_strong_password_here
# Секрет для подписи JWT (32+ случайных байт в hex/base64)
# Сгенерировать: python3 -c "import secrets; print(secrets.token_hex(32))"
WEB_SESSION_SECRET=replace-me-with-random-64-char-string
WEB_SESSION_TTL_HOURS=24
